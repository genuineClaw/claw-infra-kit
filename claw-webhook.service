[Unit]
Description=OpenClaw GitHub Webhook Receiver
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/claw-infra-kit
ExecStart=/usr/bin/uv run --directory packages/webhook webhook.server:main
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target